#include <stdio.h>
#include<math.h>
int main ()
{
    float r, Area, Circumference;
    printf("Enter the radius of the circle:\n");
    scanf("%f",&r);
    Circumference= 2*3.14*r;
    Area=3.14*r*r;
    printf("The Area of the circle is %f\n",Area);
    printf("The Circumference of the circle is %f",Circumference);
    return 0;
}
    
