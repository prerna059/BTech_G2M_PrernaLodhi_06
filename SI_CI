#include <stdio.h>
#include<math.h>
int main ()
{
    float p,r,t;
    printf("Enter Principal:\n");
    scanf("%f",&p);
    printf("Enter rate:\n");
    scanf("%f",&r);
    printf("Enter Time:\n");
    scanf("%f",&t);
    float SI;
    SI=p*r*t/100;
    printf("Simple Interest:%f",SI);
    printf("\nThe Amount is %f", SI+p);
    float CI;
    float CI_Amount;
    CI=p*pow((1+r),t)-p;
    printf("\nThe compound interest is %f",CI);
    return 0;
}
    
